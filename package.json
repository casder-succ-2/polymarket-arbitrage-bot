{
  "name": "polymarket-arbitrage-bot",
  "version": "1.0.0",
  "description": "Polymarket 15m up/down dump-and-hedge trading bot (TypeScript)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "sim": "node dist/main.js --simulation",
    "prod": "node dist/main.js --production",
    "dev": "tsx src/main.ts",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@polymarket/builder-relayer-client": "^0.0.8",
    "@polymarket/clob-client": "^3.0.0",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "tslib": "^2.8.1",
    "viem": "^2.47.10",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
