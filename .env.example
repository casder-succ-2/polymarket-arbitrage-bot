# Скопируйте в .env. Секреты не коммитьте.
#
# npm install && npm run build
# Симуляция:  npm run sim
# Прод:       PRODUCTION=true, PRIVATE_KEY, затем npm run prod
#             (или PRODUCTION=true в .env и npm start)

# =============================================================================
# Режим
# =============================================================================
PRODUCTION=false

# Для PRODUCTION=true
# PRIVATE_KEY=

# 0 = EOA. 1 = Magic. 2 = browser proxy (+ PROXY_WALLET_ADDRESS). По умолчанию: 2
SIGNATURE_TYPE=2

# PROXY_WALLET_ADDRESS=

CHAIN_ID=137

# Бюджет рыночного BUY: shares * ref_price * ORDER_USD_SLIPPAGE_MULT (FOK)
ORDER_USD_SLIPPAGE_MULT=1.02

# =============================================================================
# API
# =============================================================================
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com

# Опционально: явные L2-ключи (все три сразу) — иначе derive из PRIVATE_KEY
# API_KEY=
# API_SECRET=
# API_PASSPHRASE=

# =============================================================================
# Redeem
# =============================================================================
AUTO_REDEEM=true
# POLYGON_RPC_URL=
REDEEM_USE_RELAYER=false
# POLY_BUILDER_API_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=
RELAYER_URL=https://relayer-v2.polymarket.com

# =============================================================================
# Мониторинг
# =============================================================================
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
WEBSOCKET_DEBOUNCE_MS=0
MONITOR_USE_HTTP=false
CHECK_INTERVAL_MS=1000
MARKET_CLOSURE_CHECK_INTERVAL_SECONDS=20

# =============================================================================
# Рынки (slug btc-updown-15m-… и т.д.)
# =============================================================================
MARKETS=btc
UP_DOWN_TIMEFRAME=15m

# =============================================================================
# Стратегия dump-and-hedge
# =============================================================================
DUMP_HEDGE_SHARES=10
DUMP_HEDGE_SUM_TARGET=0.95
DUMP_HEDGE_MOVE_THRESHOLD=0.15
DUMP_HEDGE_WINDOW_MINUTES=2
DUMP_HEDGE_STOP_LOSS_MAX_WAIT_MINUTES=5
DUMP_HEDGE_STOP_LOSS_PERCENTAGE=0.2
DUMP_HEDGE_STOP_LOSS_USE_LIMIT_LADDER=true

# =============================================================================
# Логи периодов
# =============================================================================
HISTORY_LOG_DIR=logs
